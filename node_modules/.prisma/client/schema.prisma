generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  nome         String
  username     String     @unique
  passwordHash String     @map("password_hash")
  role         Role       @default(operator)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  registros    Registro[]

  @@map("users")
}

model Registro {
  id          Int       @id @default(autoincrement())
  nomePessoa  String    @map("nome_pessoa")
  tipoAcesso  String    @map("tipo_acesso")
  temVeiculo  Boolean   @default(false) @map("tem_veiculo")
  modeloCarro String?   @map("modelo_carro")
  placa       String?
  bloco       String?
  apartamento String?
  dataEntrada DateTime  @map("data_entrada")
  dataSaida   DateTime? @map("data_saida")
  criadoPorId Int       @map("criado_por_user_id")
  criadoPor   User      @relation(fields: [criadoPorId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("registros")
}

enum Role {
  admin
  operator
}
